# =============================================================================
# ExitusRO backend - environment variables
# Copy this file to `.env` and fill in the values.
# =============================================================================

# ---- Database (Supabase Postgres) -------------------------------------------
# Get this string from:
#   Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the "Transaction" pooler (port 6543) for normal app traffic.
# Format: jdbc:postgresql://<host>:6543/postgres?sslmode=require
DB_URL=jdbc:postgresql://aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_USERNAME=postgres.kqoomixehwzzpfitazlt
DB_PASSWORD=replace-with-your-db-password
DB_POOL_SIZE=10

# ---- Supabase -----------------------------------------------------------------
SUPABASE_URL=https://kqoomixehwzzpfitazlt.supabase.co

# Used to verify Supabase Auth JWTs.
# Dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=replace-with-jwt-secret

# Server-side only (NEVER expose to frontend).
# Dashboard -> Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

SUPABASE_STORAGE_BUCKET=case-documents

# ---- Email (Resend) ----------------------------------------------------------
# Optional in dev: if not set the EmailService logs messages instead of sending.
RESEND_API_KEY=
RESEND_FROM=ExitusRO <no-reply@exitusro.ro>

# ---- HTTP --------------------------------------------------------------------
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SPRING_PROFILES_ACTIVE=dev
